{
  "name": "pngjs",
  "version": "7.0.0",
  "description": "PNG encoder/decoder for Node.js with async & sync APIs, supporting any bit size and interlace.",
  "contributors": [
    "Alexandre Paré",
    "Gaurav Mali",
    "Gusts Kaksis",
    "Kuba Niegowski",
    "Luke Page",
    "Pietajan De Potter",
    "Steven Sojka",
    "liangzeng",
    "Michael Vogt",
    "Xin-Xin Wang",
    "toriningen",
    "Eugene Kulabuhov"
  ],
  "homepage": "https://github.com/pngjs/pngjs",
  "keywords": [
    "PNG",
    "decoder",
    "encoder",
    "js-png",
    "node-png",
    "parser",
    "png",
    "png-js",
    "png-parse",
    "pngjs"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./lib/png.js",
  "exports": {
    ".": "./lib/png.js"
  },
  "imports": {
    "#lib/*": "./lib/*.js"
  },
  "directories": {
    "lib": "lib",
    "example": "examples",
    "test": "test"
  },
  "files": [
    "lib/",
    "wasm/png.js",
    "wasm/png.wasm"
  ],
  "scripts": {
    "build:wasm": "cargo build --manifest-path wasm/Cargo.toml --target wasm32-unknown-unknown --release && cp wasm/target/wasm32-unknown-unknown/release/pngjs_wasm.wasm wasm/png.wasm",
    "prepack": "npm run build:wasm",
    "test": "npm run build:wasm && npm run lint && npm run prettier:check && node --test test/*-spec.js",
    "lint": "eslint .",
    "prettier:write": "prettier --write .",
    "prettier:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/pngjs/pngjs.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pngjs/pngjs/issues"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1"
  }
}
